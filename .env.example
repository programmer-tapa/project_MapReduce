# ==============================================================================
# MapReduce Cluster Configuration Environment Variables
# ==============================================================================

# Storage adapter type: 'disk' or 's3'
STORAGE_TYPE=s3

# S3 configuration details (default settings for local MinIO service)
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=mapreduce

# Coordinator gRPC endpoint (used by worker to report and request tasks)
COORDINATOR_ADDR=localhost:9090

# Number of worker task daemon container replicas to scale
WORKER_REPLICAS=3

# Grafana admin credentials
GRAFANA_ADMIN_PASSWORD=admin

COORDINATOR_PORT=9093
COORDINATOR_METRICS_PORT=9094
PROMETHEUS_PORT=9095
GRAFANA_PORT=3004
MINIO_API_PORT=9005
MINIO_CONSOLE_PORT=9006
